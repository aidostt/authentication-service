# MongoDB connection (identity store; migration to PostgreSQL tracked in ADR-0002).
MONGO_URI=
MONGO_USER=
MONGO_PASS=
# bcrypt cost factor (integer; defaults to 12 when unset or invalid).
PASSWORD_COST=
# HMAC secret used to sign JWTs. Must match the API gateway. Required.
JWT_SIGNING_KEY=
# Host this service advertises to gRPC peers.
GRPC_HOST=
# Application/issuer name embedded in issued tokens.
APP=
